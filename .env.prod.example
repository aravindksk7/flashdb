# FlashDB Production Environment Configuration
# Copy to .env.prod and customize for your deployment

# ============================================================================
# Database Configuration
# ============================================================================

# SQL Server connection
DB_PASSWORD=FlashDB@Prod123
DB_HOST=sql-server
DB_PORT=1433
DB_USER=sa

# Data persistence paths (host machine)
SQL_DATA_PATH=./data/sql
BACKUP_PATH=./data/backups
LOG_PATH=./logs

# ============================================================================
# Backup Service Configuration
# ============================================================================

# Backup interval in hours
BACKUP_INTERVAL_HOURS=4

# Backup retention in days
BACKUP_RETENTION_DAYS=30

# Timezone for scheduled backups
TZ=UTC

# ============================================================================
# API Configuration
# ============================================================================

# API environment
NODE_ENV=production

# API port (internal, not exposed)
API_PORT=3001

# Log level: error, warn, info, debug
LOG_LEVEL=info

# API instances (automatically scaled with docker-compose)
API_REPLICAS=5

# ============================================================================
# GUI Configuration
# ============================================================================

# GUI port (internal, proxied through reverse proxy)
GUI_PORT=3000

# API URL for GUI
VITE_API_URL=http://reverse-proxy:8080/api

# ============================================================================
# Reverse Proxy / Load Balancer Configuration
# ============================================================================

# External domain/IP for HTTPS
DOMAIN=localhost

# SSL certificate paths (relative to docker-compose.prod.yml)
SSL_CERT_PATH=./docker/ssl/cert.pem
SSL_KEY_PATH=./docker/ssl/key.pem

# Rate limiting
API_RATE_LIMIT=100r/s
GENERAL_RATE_LIMIT=50r/s

# ============================================================================
# Resource Limits
# ============================================================================

# CPU and Memory limits for containers
SQL_CPUS=2
SQL_MEMORY=4G

API_CPUS=0.5
API_MEMORY=512M

GUI_CPUS=0.5
GUI_MEMORY=256M

PROXY_CPUS=1
PROXY_MEMORY=512M

BACKUP_CPUS=0.5
BACKUP_MEMORY=512M

# ============================================================================
# Monitoring & Alerts
# ============================================================================

# Health check intervals
HEALTH_CHECK_INTERVAL=10s

# Service restart policy
RESTART_POLICY=on-failure:5

# ============================================================================
# Security
# ============================================================================

# Enable HTTPS (set to true in production)
ENABLE_HTTPS=false

# Security headers
X_FRAME_OPTIONS=SAMEORIGIN
X_CONTENT_TYPE_OPTIONS=nosniff
X_XSS_PROTECTION=1; mode=block

# ============================================================================
# Logging & Debugging
# ============================================================================

# Debug mode (disable in production)
DEBUG=false

# Verbose logging
VERBOSE_LOGS=false

# Log file retention days
LOG_RETENTION_DAYS=30
