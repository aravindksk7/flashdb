# Dockerfile for FlashDB testing environment
# Minimal test runner - tests are meant to run on Windows with PowerShell

FROM node:18-alpine

# Install runtime dependencies
RUN apk add --no-cache curl git bash

WORKDIR /app/flashdb

# Create test results directory
RUN mkdir -p /app/test-results

# Copy FlashDB source
COPY . .

# Simple entrypoint that keeps container running
ENTRYPOINT ["sh", "-c", "echo 'Test runner ready. Run tests on Windows: ./docker/test-scenario.ps1' && tail -f /dev/null"]
